# Blackwings environment variables
# Copy this file to ".env" and fill in real values. ".env" is git-ignored.

# Google Maps JavaScript API key.
# Create a NEW key in Google Cloud Console and restrict it by HTTP referrer
# (your domain) + APIs (Maps JavaScript API, Places API, Directions API).
# Do NOT reuse the old unrestricted key.
VITE_GOOGLE_MAPS_API_KEY=
